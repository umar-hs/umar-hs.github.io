@article{kirkegaard_solid_2021,
	title = {Solid numbers, missed opportunities: {Review} of {The} intelligence of nations},
	volume = {15},
	issn = {2330-2933},
	shorttitle = {Solid numbers, missed opportunities},
	doi = {10.1037/ebs0000181},
	abstract = {Reviews the book, The Intelligence of Nations by Richard Lynn and David Becker (2019). The Intelligence of Nations is the latest iteration of Lynn’s long-running compilation of data on the intelligence of countries. The book has four chapters, the first of which briefly (6 pages) introduces the reader to the question of why some countries are richer than others (Smith, 1776). This chapter serves to summarize the three previous books by Lynn and Vanhanen on the same topic (Lynn \& Vanhanen, 2002, 2006, 2012). In his summary, however, Lynn neglects to mention his own 1978 book chapter (Lynn, 1978) in which he first summarized test results for ethnic groups and countries. All in all, the book is similar to the predecessors in presentation and discussion of material. There is little to no attempt at using advanced statistical methods to clarify matters of disputed causality or even just the relative importance of predictors. Existing studies on the question are not seriously discussed either, and an important opportunity is missed. The presentation is quite dry. On the positive side, the book describes the current state-of-the-art calculations for national IQs, introduces the reader to the open data set of national IQs, shows their high replicability, and reviews their use by tens if not hundreds of other researchers. This last point bears noting because it shows that, despite criticism, the national IQ subfield has become a very productive research program (Rindermann, 2013b; Urbach, 1974a, 1974b). In fact, one might say that national IQs are getting quite popular because various other groups have begun publishing very similar national cognitive ability estimates (Angrist, Djankov, Goldberg, \& Patrinos, 2019; Coutrot et al., 2018; Lim et al., 2018), even if they call it something other than intelligence and rarely cite the pioneering efforts of Richard Lynn and colleagues. (PsycInfo Database Record (c) 2021 APA, all rights reserved)},
	journal = {Evolutionary Behavioral Sciences},
	author = {Kirkegaard, Emil O. W.},
	year = {2021},
	note = {Place: US
Publisher: Educational Publishing Foundation},
	keywords = {Cognitive Ability, Intelligence, Intelligence Quotient, Causality, Countries},
	pages = {389--397},
	file = {Snapshot:D\:\\[Aristu]\\Zotero\\storage\\SLSNHIQR\\2019-46163-001.html:text/html},
}

